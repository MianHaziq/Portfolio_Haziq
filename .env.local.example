# ─── EmailJS (contact form) ────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your EmailJS dashboard.
# These are NEXT_PUBLIC_* because EmailJS is a client-side service — the keys are
# meant to be exposed in the browser. Restrict abuse in the EmailJS dashboard
# (allowed origins + reCAPTCHA), not by hiding the keys.
#
# Setup steps:
#   1. Create a free account at https://www.emailjs.com
#   2. Add an Email Service (Gmail, etc.)            → Service ID
#   3. Create an Email Template with these variables:
#        {{from_name}}  {{from_email}}  {{reply_to}}  {{message}}  {{to_name}}
#                                                     → Template ID
#   4. Account → General → Public Key                → Public Key
#   5. Paste all three below, then restart `npm run dev`.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_1vbx67c
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_z1fetik
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=tRd3GQVovWkNoxGoM
