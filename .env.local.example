# ─── Site URL (SEO) ─────────────────────────────────────────────────────────
# Canonical origin used for metadataBase, canonicals, OG image URLs, the sitemap
# and robots.txt. Defaults to https://haziqnazeer.online when unset. Override it
# for preview/staging deployments (e.g. a *.vercel.app URL). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://haziqnazeer.online

# ─── Search engine verification (optional) ──────────────────────────────────
# Paste the verification tokens from Google Search Console and Bing Webmaster
# Tools. When set, the <meta> tags render automatically; leave blank to omit.
#   Google: Search Console → Settings → Ownership verification → HTML tag
#   Bing:   Webmaster Tools → verify → Meta tag (msvalidate.01)
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# ─── EmailJS (contact form) ────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your EmailJS dashboard.
# These are NEXT_PUBLIC_* because EmailJS is a client-side service — the keys are
# meant to be exposed in the browser. Restrict abuse in the EmailJS dashboard
# (allowed origins + reCAPTCHA), not by hiding the keys.
#
# Setup steps:
#   1. Create a free account at https://www.emailjs.com
#   2. Add an Email Service (Gmail, etc.)            → Service ID
#   3. Create an Email Template with these variables:
#        {{from_name}}  {{from_email}}  {{reply_to}}  {{message}}  {{to_name}}
#                                                     → Template ID
#   4. Account → General → Public Key                → Public Key
#   5. Paste all three below, then restart `npm run dev`.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
